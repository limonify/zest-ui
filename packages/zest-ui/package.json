{
  "name": "@limonify/zest-ui",
  "version": "0.1.4",
  "description": "Base UI for React Native — headless, unstyled, accessible primitive components.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/limonify/zest-ui.git",
    "directory": "packages/zest-ui"
  },
  "homepage": "https://github.com/limonify/zest-ui#readme",
  "bugs": {
    "url": "https://github.com/limonify/zest-ui/issues"
  },
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "source": "./src/index.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "react-native": "./src/index.ts",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "src",
    "lib",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.test-d.ts"
  ],
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint src",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf lib",
    "prepack": "bun run clean && bun run build"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-native": ">=0.79.0",
    "react-native-gesture-handler": ">=3.0.0"
  },
  "devDependencies": {
    "@babel/runtime": "^8.0.0",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "expo": "~57.0.7",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.2",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~3.1.0",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "@floating-ui/react-native": "^0.10.10"
  },
  "peerDependenciesMeta": {
    "react-native-gesture-handler": {
      "optional": true
    }
  }
}
